# =============================================================================
# Local Engine .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
.eggs/
*.manifest
*.spec.bak

# -----------------------------------------------------------------------------
# 构建输出
# -----------------------------------------------------------------------------
dist/
release/
build_env/

# 构建中间文件 (保留 build/ 目录结构，但忽略构建产物)
*.dist/

# Nuitka 相关
nuitka-crash-report.xml
*.pyi

# -----------------------------------------------------------------------------
# 测试输出
# -----------------------------------------------------------------------------
tests/output/
debug_screenshots/
# -----------------------------------------------------------------------------
# 日志
# -----------------------------------------------------------------------------
logs/
*.log

# -----------------------------------------------------------------------------
# 配置文件 (敏感信息)
# -----------------------------------------------------------------------------
config/api_keys.json

# -----------------------------------------------------------------------------
# IDE / 编辑器
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# -----------------------------------------------------------------------------
# 临时文件
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
.cache/
*.png
.uv/
*.json
*.txt

# -----------------------------------------------------------------------------
# Jupyter Notebooks 检查点
# -----------------------------------------------------------------------------
.ipynb_checkpoints/


