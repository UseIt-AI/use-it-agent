# 开源本地版 — 最小配置（与 ``src/useit_studio/gateway`` 配合使用）
# 复制为仓库根目录 ``.env`` 后按需修改

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001

# 本地 useit-gateway：是否在网关进程内挂载 AI_Run（默认 1）。设为 0 时网关不嵌入，
# 请本机另启独立 AI_Run（默认监听 8326），网关仍只连本机 get_ai_run_url()。
# USEIT_GATEWAY_EMBED_AI_RUN=0

# 嵌入或统一进程下默认网关↔AI_Run 进程内直连（不经 HTTP）。若要强制走本机 HTTP：USEIT_IN_PROCESS_AI_RUN=0
# USEIT_IN_PROCESS_AI_RUN=0

# WORKFLOW_DEBUG=0
# MESSAGE_LOG_ENABLED=1

#GOOGLE_API_KEY=
